# ════════════════════════════════════════════════════════════════════════════════
# PORTKEY CONFIGURATION (Recommended - Gateway for multiple LLM providers)
# ════════════════════════════════════════════════════════════════════════════════

# Enable Portkey gateway (set to "false" to use direct OpenAI)
USE_PORTKEY=true

# Your Portkey API key (get from https://app.portkey.ai/)
PORTKEY_API_KEY=your-portkey-api-key-here

# Base URL for Portkey API (default is usually fine)
PORTKEY_BASE_URL=https://api.portkey.ai/v1

# Provider to use through Portkey ("openai", "anthropic", "cohere", "together", etc.)
PORTKEY_PROVIDER=openai

# Optional: Virtual key for automatic provider rotation/fallback
# PORTKEY_VIRTUAL_KEY=your-virtual-key-here

# Optional: Enable caching for repeated queries
# PORTKEY_CACHE=true
# PORTKEY_CACHE_TTL=3600

# ════════════════════════════════════════════════════════════════════════════════
# MODEL CONFIGURATION (Works with any provider through Portkey)
# ════════════════════════════════════════════════════════════════════════════════

# OpenAI Models (when PORTKEY_PROVIDER=openai)
OPENAI_ANSWER_MODEL=gpt-4
OPENAI_RETRIEVAL_MODEL=gpt-4
OPENAI_WEB_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Example: Using Anthropic Claude through Portkey
# PORTKEY_PROVIDER=anthropic
# OPENAI_ANSWER_MODEL=claude-3-opus-20240229
# OPENAI_RETRIEVAL_MODEL=claude-3-sonnet-20240229
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Example: Using Cohere through Portkey
# PORTKEY_PROVIDER=cohere
# OPENAI_ANSWER_MODEL=command-r-plus
# OPENAI_RETRIEVAL_MODEL=command-r
# OPENAI_EMBEDDING_MODEL=embed-english-v3.0

# ════════════════════════════════════════════════════════════════════════════════
# LEGACY DIRECT OPENAI CONFIGURATION (Only used when USE_PORTKEY=false)
# ════════════════════════════════════════════════════════════════════════════════

# Direct OpenAI API key (only needed if not using Portkey)
OPENAI_API_KEY=your-openai-api-key-here

# ════════════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ════════════════════════════════════════════════════════════════════════════════

# Environment (development, staging, production)
ENVIRONMENT=development