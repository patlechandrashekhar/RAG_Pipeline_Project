# ════════════════════════════════════════════════════════════════════════════════
# OPTION 1: Direct Claude API (Recommended for Agent SDK)
# ════════════════════════════════════════════════════════════════════════════════

# Anthropic API key for Claude (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AWS credentials for Amazon Titan embeddings (get from AWS console)
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_REGION=us-east-1

# Disable Portkey if using direct API
AGENTSDK_USE_PORTKEY=false

# ════════════════════════════════════════════════════════════════════════════════
# OPTION 2: Using Portkey Gateway (if you have Portkey setup)
# ════════════════════════════════════════════════════════════════════════════════

# Enable Portkey routing
# AGENTSDK_USE_PORTKEY=true
# PORTKEY_API_KEY=your-portkey-api-key-here
# PORTKEY_BASE_URL=https://api.portkey.ai/v1
# PORTKEY_PROVIDER=anthropic
# PORTKEY_ANTHROPIC_PROVIDER=anthropic

# Optional: Virtual key for load balancing
# PORTKEY_VIRTUAL_KEY=your-virtual-key-here

# ════════════════════════════════════════════════════════════════════════════════
# MODEL CONFIGURATION (Optional - defaults are fine)
# ════════════════════════════════════════════════════════════════════════════════

# Claude model for main responses (default: claude-3-opus-20240229)
CLAUDE_MODEL=claude-3-opus-20240229

# Claude model for query expansion (default: claude-3-haiku-20240307)
CLAUDE_QUERY_MODEL=claude-3-haiku-20240307

# Titan embedding model (default: amazon.titan-embed-text-v2:0)
TITAN_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# Environment
ENVIRONMENT=development

# Disable AWS metadata service (prevents warnings)
AWS_EC2_METADATA_DISABLED=true